# ==============================================================================
# MAIN REPOSITORY .gitignore
# ==============================================================================

# OS & System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*~

# IDEs & Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.prettierignore

# Node & Package Managers
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*
.npm/

# Environment Variables & Secrets (CRITICAL)
.env
.env.*
!.env.example
*.pem
*.key
*.cert
certificates/
secrets/
config/local.json
credentials.json
client_secret.json

# Build & Deployment caches
.serverless/
.netlify/
.cache/

# Coverage & Testing
coverage/
.nyc_output/

# Common Ignore Rules covering subdirectories
**/node_modules/
**/.env
**/.env.*
**/build/
**/dist/
**/coverage/
