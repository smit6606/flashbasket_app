# ==============================================================================
# NODE.JS BACKEND .gitignore
# ==============================================================================

# Database / Runtime data
logs
*.log
pids
*.pid
*.seed
*.pid.lock
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov
.nyc_output

# NodeJS / NPM / Package Managers
node_modules/
.npm
.eslintcache
.node_repl_history
jspm_packages/
package-lock.json
yarn.lock

# Build & TypeScript
build/
dist/
*.tsbuildinfo

# Environment variables & Secrets
.env
.env.test
.env.production
.env.local
.env.development
*.pem
*.key
credentials/
ssh/
certs/

# OS / Editor
.DS_Store
.vscode/
.idea/
*.swp

# Docker
docker-compose.override.yml
.dockerignore
